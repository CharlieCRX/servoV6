{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake-configure",
            "type": "shell",
            "command": "D:\\develop\\Qt6\\Tools\\CMake_64\\bin\\cmake.exe",
            "args": [
                "-S",
                "${workspaceFolder}",
                "-B",
                "${workspaceFolder}/build",
                "-G",
                "MinGW Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug",
                "-DCMAKE_CXX_STANDARD=20",
                "-DCMAKE_AUTOMOC=OFF",
                "-DCMAKE_AUTORCC=OFF",
                "-DCMAKE_AUTOUIC=OFF",
                "-DCMAKE_MAKE_PROGRAM=D:/develop/Qt6/Tools/mingw1310_64/bin/mingw32-make.exe",
                "-DCMAKE_C_COMPILER=D:/develop/Qt6/Tools/mingw1310_64/bin/gcc.exe",
                "-DCMAKE_CXX_COMPILER=D:/develop/Qt6/Tools/mingw1310_64/bin/g++.exe",
                "-DCMAKE_PREFIX_PATH=D:/develop/Qt6/6.11.0/mingw_64"
            ],
            "options": {
                "env": {
                    "PATH": "D:\\develop\\Qt6\\Tools\\mingw1310_64\\bin;D:\\develop\\Qt6\\6.11.0\\mingw_64\\bin;${env:PATH}"
                }
            },
            "group": {
                "kind": "build"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "CMake 配置（MinGW + Debug 模式）"
        },
        {
            "label": "cmake-build",
            "type": "shell",
            "command": "D:\\develop\\Qt6\\Tools\\CMake_64\\bin\\cmake.exe",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "all",
                "--parallel",
                "8"
            ],
            "options": {
                "env": {
                    "PATH": "D:\\develop\\Qt6\\Tools\\mingw1310_64\\bin;D:\\develop\\Qt6\\6.11.0\\mingw_64\\bin;${env:PATH}"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": [
                "cmake-configure"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "多线程编译 unit_tests（自动检测 CPU 核心数）"
        },
        {
            "label": "cmake-clean",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "if exist \"${workspaceFolder}\\build\" rmdir /s /q \"${workspaceFolder}\\build\""
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "完全删除 build 目录"
        },
        {
            "label": "cmake-clean-rebuild",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "if exist \"${workspaceFolder}\\build\" rmdir /s /q \"${workspaceFolder}\\build\""
            ],
            "group": "build",
            "dependsOn": [],
            "problemMatcher": [],
            "detail": "删除 build → 再运行 cmake-build 重新配置并编译"
        }
    ]
}
